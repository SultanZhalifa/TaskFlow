{
    "env": {
        "browser": true,
        "es2021": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "rules": {
        "no-console": ["warn", { "allow": ["error"] }],
        "no-unused-vars": "warn",
        "eqeqeq": "error",
        "no-var": "error",
        "prefer-const": "warn"
    }
}
